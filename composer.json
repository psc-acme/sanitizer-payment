{
    "name": "psc-acme/sanitizer-payment",
    "description": "Package sanitizer-payment for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\SanitizerPayment\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "doctrine/orm": "^3.0",
        "doctrine/collections": "^2.0",
        "doctrine/doctrine-bundle": "^2.13",
        "league/csv": "^9.0",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "rector/rector": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}